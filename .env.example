# Copy this file to .env and fill in your credentials

# UKHO Admiralty API — free Discovery tier
# Register at: https://admiraltyapi.portal.azure.com/
UKHO_API_KEY=your_ukho_admiralty_api_key_here

# Copernicus Marine Service (CMEMS) — free account
# Register at: https://marine.copernicus.eu/
# Provides real hydrodynamic model currents (1.5 km grid, hourly, 7-day forecast)
# covering English Channel, Thames Estuary, North Sea
# If not set, the app falls back to station-based stream estimation
CMEMS_USERNAME=your_cmems_username
CMEMS_PASSWORD=your_cmems_password
